# Puerto del servidor
PORT=3001

# Conexión a PostgreSQL
# Para docker-compose local, usar: postgresql://pqr:pqr@postgres:5432/pqr
DATABASE_URL=postgresql://usuario:password@localhost:5432/pqr

# Desactiva SSL para Postgres local (docker-compose). En RDS dejar sin definir (SSL activado).
PGSSL=false

# Clave secreta para firmar tokens JWT — usa una cadena larga y aleatoria
JWT_SECRET=cambia_esto_por_una_clave_larga_y_aleatoria

# Credenciales del admin por defecto (se usan solo al crear el primer admin)
ADMIN_EMAIL=admin@tupqr.edu.co
ADMIN_PASSWORD=cambia_esto_por_una_password_segura

# URL del frontend (para CORS)
FRONTEND_URL=http://localhost:5173

# API Key de OpenRouter
OPENROUTER_API_KEY=sk-or-...

# Configuración de email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=tucorreo@gmail.com
EMAIL_PASS=tu_app_password_de_gmail
EMAIL_FROM="Sistema PQR" <tucorreo@gmail.com>

# URL pública del frontend (para los botones en los emails)
APP_URL=http://localhost:5173
